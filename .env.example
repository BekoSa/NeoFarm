# --- General ---
TZ=UTC

# --- Postgres ---
POSTGRES_DB=farm
POSTGRES_USER=farm
POSTGRES_PASSWORD=farm
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Farm server ---
# API key that clients/CLI must send in `X-Farm-Token`.
FARM_API_TOKEN=change-me-please
# Where the API listens inside the container; map to host in docker-compose.
FARM_HOST=0.0.0.0
FARM_PORT=5000
# Path inside the container to the YAML config (mounted from ./config.yml).
FARM_CONFIG=/app/config.yml
# CORS origins for the frontend (comma-separated, * for all).
FARM_CORS_ORIGINS=*

# --- Frontend ---
# Public URL of the API for the browser. If you serve UI on the same host,
# leave it as the default; for remote clients, use http://<farm-ip>:5000
VITE_API_BASE=http://localhost:5000
VITE_WS_BASE=ws://localhost:5000
